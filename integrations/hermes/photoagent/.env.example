# Copy these values into ~/.hermes/profiles/photoagent/.env after creating
# a separate Telegram bot or a separate Telegram channel/group for photo-agent.
#
# Recommended:
# 1. Create a new bot with BotFather, e.g. Photo Ingest Agent.
# 2. Create a private Telegram group/channel for photo work.
# 3. Add the new bot to that group/channel.
# 4. Put your Telegram user ID in TELEGRAM_ALLOWED_USERS.
# 5. Put the group/channel chat ID in TELEGRAM_HOME_CHANNEL.

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_HOME_CHANNEL_NAME=Photo Agent

# Optional if you want to force local execution style.
HERMES_BACKGROUND_NOTIFICATIONS=result
